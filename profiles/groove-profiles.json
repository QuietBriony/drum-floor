{
  "version": 1,
  "policy": {
    "stores_audio": false,
    "stores_samples": false,
    "stores_metadata_only": true,
    "purpose": "drum feel generation profile, not copying"
  },
  "profiles": [
    {
      "id": "mixture_shout",
      "label": "Mixture Shout",
      "description": "Heavy riff and shout vocal driven style with strong snare focus and section fills.",
      "input_bias": {
        "vocal_intensity": "high",
        "bass_density": "high",
        "guitar_chop": "high",
        "groove_push_pull": "forward",
        "humanize": "medium"
      },
      "drum_translation": {
        "kick": ["lock_to_bass_hits", "emphasize_downbeat_1", "optional_double_kick_at_chorus"],
        "snare": ["strong_backbeat", "extra_ghosted_ghost_on_4", "fill_pre_refrain"],
        "hat": ["tight_8th", "occasional_16th_stabs"],
        "ghost_notes": ["short_and_sparse"],
        "fill": ["2_or_4_bar_pre_transition", "short_roar_fill"],
        "crash": ["section_entry", "verse_to_chorus_transition"],
        "transition": ["lift_on_last_beat", "tempo_locked_ramp"]
      },
      "avoid": ["overly_sparse_hat", "flat_velocity"]
    },
    {
